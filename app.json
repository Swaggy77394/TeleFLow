{
  "name": "TELEFLOW",
  "description": "A Telegram Forwarder Bot, written in Python with Telethon.",
  "logo": "https://files.catbox.moe/fdkxi4.jpg",
  "keywords": [
    "python3",
    "telegram",
    "bot",
    "TELEFLOW",
    "ForwarderBot",
    "telegram-bot",
    "telethon"
  ],
  "env": {
    "API_ID": {
      "description": "Get this value from https://my.telegram.org",
      "value": "",
      "required": true
    },
    "API_HASH": {
      "description": "Get this value from https://my.telegram.org",
      "value": "",
      "required": true
    },
    "BOT_TOKEN": {
      "description": "A Bot's token from Botfather",
      "value": "",
      "required": true
    },
    "OWNER_ID": {
      "description": "Go @AsHackerassr and get your user id.",
      "value": "1217850333",
      "required": true
    },
    "STRING_SESSION": {
      "description": "A Telethon String Session from @TeleFlow_TelegramForwardbot created by @AsHackerassr.",
      "value": "",
      "required": true
    },
    "HEROKU_API_KEY": {
      "description": "Your Heroku account's API key",
      "value": "",
      "required": false
    },
    "HEROKU_APP_NAME": {
      "description": "Your heroku app name",
      "value": "",
      "required": false
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    },
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest.git"
    }
  ],
  "stack": "container"
}